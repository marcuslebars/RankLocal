# ─────────────────────────────────────────────────────────────────────────────
# RankLocal Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────────────
# Your Stripe Payment Link or Checkout URL for the Local Launch Kit ($997)
# Create one at: https://dashboard.stripe.com/payment-links
# After payment, configure the success URL to redirect to: https://ranklocal.ca/onboarding
VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/your_link_here

# ── Onboarding Webhook ────────────────────────────────────────────────────────
# Where to send onboarding form submissions.
# Options:
#   - Formspree:  https://formspree.io/f/your_form_id
#   - Make/n8n:   Your webhook URL
#   - HubSpot:    Your HubSpot form submission endpoint
VITE_ONBOARDING_WEBHOOK_URL=https://formspree.io/f/your_form_id

# ── Notification Email ────────────────────────────────────────────────────────
# Internal email to notify when a new onboarding form is submitted
# (used if webhook supports email notifications)
VITE_NOTIFICATION_EMAIL=hello@ranklocal.ca
